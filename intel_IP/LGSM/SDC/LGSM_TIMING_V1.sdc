# ----------------------------------------------------
# 檔案名稱: LGSM_TIMING_V1.sdc
# 目的: 為 LGSM_TOP 專案設定 SDC 時序約束
# ----------------------------------------------------

# 1. 外部主時鐘約束 (CLOCK_50M)
# ----------------------------------------------------
set CLOCK_50M_PERIOD 20.000
create_clock -name {CLOCK_50M} -period $CLOCK_50M_PERIOD [get_ports {CLOCK_50M}]


# 2. 自動生成所有 PLL 時鐘約束
# ----------------------------------------------------
# TimeQuest 將自動掃描 PLL 並生成所有衍生時鐘，包括 c2 的 -45 度相位。
derive_pll_clocks


# 3. 處理 PLL 未鎖定狀態
# ----------------------------------------------------
# 這是為了防止在 PLL 尚未鎖定時，分析器使用這些不穩定的時鐘。
set_false_path -setup -hold -to [get_keepers {pll_inst|*|clk[*]}]